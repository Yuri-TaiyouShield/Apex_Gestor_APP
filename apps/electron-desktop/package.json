{
  "name": "apex-gestor-electron-desktop",
  "version": "1.0.0",
  "private": true,
  "author": "Yuri Alcantara",
  "description": "Camada UI/UX Electron Desktop do Apex Gestor com AdmCalc financeiro integrado.",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "lint:js": "node --check main.cjs && node --check preload.cjs && node --check renderer/app.js"
  },
  "devDependencies": {
    "electron": "42.0.1",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "br.com.apexgestor.desktop.ui",
    "productName": "Apex Gestor Desktop UI",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "main.cjs",
      "preload.cjs",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
